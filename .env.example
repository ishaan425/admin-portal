APP_ENV=local
DATABASE_URL=postgresql://apple@localhost:5432/growqr_admin_portal
ADMIN_API_URL=http://127.0.0.1:8000

OPENAI_API_KEY=sk-your-key-here
OPENAI_RESUME_PARSE_MODEL=gpt-5.4
RESUME_PARSE_DPI=200
RESUME_PARSE_IMAGE_DETAIL=high
RESUME_PARSE_MAX_FILE_SIZE_BYTES=10485760
RESUME_PARSE_ITEM_CONCURRENCY=5
RESUME_PARSE_PAGE_CONCURRENCY=4
RESUME_PARSE_REQUEST_RETRIES=2

CLERK_SECRET_KEY=sk_test_or_live_key_here
CLERK_INVITE_REDIRECT_URL=https://app.growqr.ai/login
CLERK_INVITE_NOTIFY=true
CLERK_JWKS_URL=https://amusing-snipe-48.clerk.accounts.dev/.well-known/jwks.json
CLERK_ISSUER=https://amusing-snipe-48.clerk.accounts.dev
CLERK_AUDIENCE=
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_secret_here

AUTH_ALLOW_LOCAL_HEADERS=true
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
API_MAX_REQUEST_BODY_BYTES=15728640

STORAGE_BACKEND=local
LOCAL_STORAGE_ROOT=.local_storage
S3_BUCKET_NAME=
S3_REGION=
S3_PREFIX=growqr-admin
S3_PRESIGNED_URL_TTL_SECONDS=900

QUEUE_BACKEND=local
LOCAL_QUEUE_ROOT=.local_queue
SQS_RESUME_UPLOAD_QUEUE_URL=
